---
# ──────────────────────────────────────────────────────────────────────
# Шаблон vault.yml. Реальный vault.yml должен быть зашифрован
# командой:  ansible-vault encrypt ansible/group_vars/all/vault.yml
#
# В .gitignore прописано: ansible/group_vars/all/vault.yml — не коммитим.
# Этот example-файл — public, в репо.
# ──────────────────────────────────────────────────────────────────────

# Подписки sing-box (один или несколько URL через пробел в каждом значении).
# Поддерживаются ss:// и vless:// в plain или base64-закодированном теле.
vault_subscription_urls: >-
  https://vpnd.io/subscription/ss/<TOKEN>/?ru=1

# (опционально) Пароль для генерации новых клиентских OVPN-ключей с passphrase.
# Если используешь nopass-режим — оставь пустым.
vault_ovpn_client_passphrase: ""

# ──────────────────────────────────────────────────────────────────────
# WDTT (если включаешь роль wdtt в site.yml)
# ──────────────────────────────────────────────────────────────────────

# Главный пароль wdtt-server. Минимум 16 символов.
# Сгенерировать: openssl rand -base64 24
vault_wdtt_master_password: ""

# (опционально) Per-client пароли — мап cn → password.
# Если пусто — все клиенты ходят под master-паролем.
vault_wdtt_client_passwords: {}
  # myiphone: "..."
  # mymac:    "..."

# (опционально) WireGuard PSK для пиров (мап pubkey → psk).
# Если пусто — PSK не используется (PresharedKey не вписывается в wg0.conf).
vault_wg_peer_psks: {}
  # "oNhNWNriK5WPshCsDIeUwcYlPHT+pHBsbZcdRXgR0nk=": "<PSK для giga>"
