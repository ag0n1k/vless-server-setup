#!/usr/bin/env bash
# {{ ansible_managed }}
# Self-check VPN-шлюза. Проверяет:
#   1. ключевые systemd-сервисы (openvpn, wg, sing-box, vk-turn-proxy, ...) active
#   2. egress через sing-box (socks5h) != WAN IP сервера
#   3. NTP-синхронизация
#   4. nft-таблицы tproxy/guard на месте
#   5. ip rule fwmark + ip route в таблице tproxy
#   6. capture-интерфейсы up и присутствуют в правилах tproxy
# Дополнительно:
#   - при N подряд egress-провалах и AUTO_SWITCH=1 — дёргает sb_recover.py
#     (rotation next-нод).
#   - при ALERT_THRESHOLD подряд-фейлов любого типа — зовёт notify-tg.sh
#     один раз за инцидент, recovery-сообщение шлёт при первом OK.
# Exit 0 — всё ок, 1 — есть провалы (список в stderr).

set -u
set -o pipefail

SOCKS_PORT="{{ selfcheck_socks_port }}"
TPROXY_PORT="{{ selfcheck_tproxy_port }}"
TEST_URL="{{ selfcheck_test_url }}"
CURL_TIMEOUT="{{ selfcheck_curl_timeout }}"
EGRESS_TRIES="{{ selfcheck_egress_tries }}"
EGRESS_RETRY_DELAY="{{ selfcheck_egress_retry_delay }}"
EGRESS_DEGRADE_FAILS="{{ selfcheck_egress_degrade_fails }}"
FWMARK="{{ selfcheck_fwmark }}"
RT_TABLE="{{ selfcheck_rt_table }}"
SERVER_IP="{{ selfcheck_server_public_ip }}"
CAPTURE_IFACES=({{ selfcheck_capture_ifaces | map('quote') | join(' ') }})
NFT_TABLES=({{ selfcheck_nft_tables | map('quote') | join(' ') }})
REQUIRED_SERVICES=({{ selfcheck_required_services | map('quote') | join(' ') }})

STATE_DIR="{{ selfcheck_state_dir }}"
AUTO_SWITCH="{{ '1' if selfcheck_auto_switch_enabled else '0' }}"
AUTO_SWITCH_THRESHOLD="{{ selfcheck_auto_switch_threshold }}"
RECOVER_PATH="{{ selfcheck_recover_path }}"
RECOVER_MAX_TRIES="{{ selfcheck_recover_max_tries }}"

LOG="{{ selfcheck_log_path }}"
ALERT_THRESHOLD="{{ selfcheck_alert_threshold }}"
NOTIFY_SCRIPT="{{ selfcheck_notify_script_path }}"
SELFCHECK_UNIT="{{ selfcheck_unit_name }}.service"

{% raw %}
# Дублируем stdout/stderr в файл-лог (journal получает копию через systemd).
mkdir -p "$(dirname "${LOG}")"
exec > >(tee -a "${LOG}") 2>&1
{% endraw %}

{% raw %}
FAILS=()
EGRESS=""
EGRESS_FAILED=0
EGRESS_DEGRADED=0
EGRESS_TRY_FAILS=0
STATE_FILE="${STATE_DIR}/egress-fails"
# Общий счётчик подряд-фейлов (любой неуспех чека) — для TG-алёрта с порогом.
# Отдельно от egress-counter, который управляет auto-switch.
GENERAL_STATE_FILE="${STATE_DIR}/general-fails"
NOTIFIED_FLAG="${STATE_DIR}/notified"

fail() { FAILS+=("$1"); }

read_state() {
  if [[ -r "${STATE_FILE}" ]]; then
    cat "${STATE_FILE}" 2>/dev/null || echo 0
  else
    echo 0
  fi
}
write_state() { mkdir -p "${STATE_DIR}"; echo "$1" >"${STATE_FILE}"; }

# 1. Обязательные сервисы active
SINGBOX_ALIVE=1
for svc in "${REQUIRED_SERVICES[@]}"; do
  if ! systemctl is-active --quiet "${svc}"; then
    STATE="$(systemctl is-active "${svc}" 2>/dev/null || true)"
    fail "service ${svc}: state=${STATE:-unknown}"
    [[ "${svc}" == "sing-box.service" ]] && SINGBOX_ALIVE=0
  fi
done

# 2. Egress через sing-box (только если sing-box жив).
# Ретрай ВНУТРИ проверки: апстрим vpnd.io периодически роняет VLESS-соединение
# (outbound EOF), одиночная осечка не должна считаться egress-провалом и крутить
# auto-switch/alert-счётчики. Успех = любая из EGRESS_TRIES попыток.
if [[ "${SINGBOX_ALIVE}" -eq 1 ]]; then
  for ((et = 1; et <= EGRESS_TRIES; et++)); do
    EGRESS="$(curl -fsS --max-time "${CURL_TIMEOUT}" \
              --proxy "socks5h://127.0.0.1:${SOCKS_PORT}" \
              "${TEST_URL}" 2>/dev/null || true)"
    EGRESS="${EGRESS//[$'\t\r\n ']}"
    # Чистый успех (вернулось и это не WAN-IP) — выходим из ретрая.
    [[ -n "${EGRESS}" && "${EGRESS}" != "${SERVER_IP}" ]] && break
    EGRESS_TRY_FAILS=$(( EGRESS_TRY_FAILS + 1 ))
    [[ "${et}" -lt "${EGRESS_TRIES}" ]] && sleep "${EGRESS_RETRY_DELAY}"
  done
  if [[ -z "${EGRESS}" ]]; then
    fail "egress: curl через socks5h://127.0.0.1:${SOCKS_PORT} ничего не вернул (${EGRESS_TRIES} попыток)"
    EGRESS_FAILED=1
  elif [[ "${EGRESS}" == "${SERVER_IP}" ]]; then
    fail "egress: трафик уходит напрямую через WAN (${EGRESS} == server_public_ip)"
    EGRESS_FAILED=1
  elif [[ "${EGRESS_DEGRADE_FAILS}" -gt 0 && "${EGRESS_TRY_FAILS}" -ge "${EGRESS_DEGRADE_FAILS}" ]]; then
    # Egress В ИТОГЕ прошёл, но мимо ушло ≥ порога попыток → нода деградирует.
    # НЕ алертим и НЕ копим alert-счётчик (egress работает), но кормим
    # счётчик auto-switch, чтобы полудохлая нода всё равно ротировалась.
    EGRESS_DEGRADED=1
    echo "$(date -u +%FT%TZ) selfcheck: egress деградирует (${EGRESS_TRY_FAILS}/${EGRESS_TRIES} попыток мимо, egress=${EGRESS})" >&2
  fi
fi

# 3. NTP-синхронизация — без точного времени TLS-handshake разваливается
NTP_SYNC="$(timedatectl show -p NTPSynchronized --value 2>/dev/null || true)"
if [[ "${NTP_SYNC}" != "yes" ]]; then
  fail "NTP: системные часы не синхронизированы (NTPSynchronized=${NTP_SYNC:-?})"
fi

# 4. nft-таблицы tproxy/guard
for tbl in "${NFT_TABLES[@]}"; do
  if ! nft list table inet "${tbl}" >/dev/null 2>&1; then
    fail "nft: таблицы inet ${tbl} нет"
  fi
done

# 5. ip rule + ip route
# ВАЖНО: вывод команды читаем в переменную и грепаем here-string'ом, а НЕ
# `ip ... | grep -q`. Под `set -o pipefail` grep -q закрывает pipe на первом
# совпадении → ip ловит SIGPIPE (rc 141) → pipe считается провалившимся →
# `if ! pipe` ЛОЖНО срабатывает как «правила нет». Флапает ~50/50, когда
# правило реально присутствует. (Тот же безопасный паттерн — в проверке #6.)
FWMARK_HEX="$(printf '0x%x' "${FWMARK}")"
RULE_DUMP="$(ip -4 rule show 2>/dev/null || true)"
if ! grep -qE "fwmark ${FWMARK_HEX} lookup ${RT_TABLE}" <<<"${RULE_DUMP}"; then
  fail "ip rule: нет 'fwmark ${FWMARK_HEX} lookup ${RT_TABLE}'"
fi

ROUTE_DUMP="$(ip route show table "${RT_TABLE}" 2>/dev/null || true)"
if ! grep -qE '^local default dev lo' <<<"${ROUTE_DUMP}"; then
  fail "ip route: в table ${RT_TABLE} нет 'local default dev lo'"
fi

# 6. Capture-интерфейсы up + ловятся tproxy-цепочкой
TPROXY_DUMP="$(nft list table inet vpn_tproxy 2>/dev/null || true)"
for iface in "${CAPTURE_IFACES[@]}"; do
  if ! ip link show "${iface}" >/dev/null 2>&1; then
    fail "iface ${iface}: интерфейс отсутствует"
    continue
  fi
  STATE="$(ip -o link show "${iface}" 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="state") print $(i+1)}')"
  if [[ "${STATE}" != "UP" && "${STATE}" != "UNKNOWN" ]]; then
    fail "iface ${iface}: state=${STATE} (ожидалось UP/UNKNOWN)"
  fi
  if ! grep -qE "iifname \"${iface}\".*tproxy to :${TPROXY_PORT}" <<<"${TPROXY_DUMP}"; then
    fail "iface ${iface}: не найден в vpn_tproxy → tproxy :${TPROXY_PORT}"
  fi
done

# ── Auto-recovery: state-counter подряд egress-провалов/деградаций ────
# Считаем только когда успели сделать сам egress-check (sing-box был жив).
# Триггерит и полный провал (EGRESS_FAILED), и частичная деградация
# (EGRESS_DEGRADED) — иначе полудохлая нода прячется за ретраем и не ротируется.
if [[ "${SINGBOX_ALIVE}" -eq 1 ]]; then
  if [[ "${EGRESS_FAILED}" -eq 1 || "${EGRESS_DEGRADED}" -eq 1 ]]; then
    FAILS_PREV="$(read_state)"
    FAILS_CUR=$(( FAILS_PREV + 1 ))
    write_state "${FAILS_CUR}"
    if [[ "${AUTO_SWITCH}" == "1" && "${FAILS_CUR}" -ge "${AUTO_SWITCH_THRESHOLD}" ]]; then
      echo "$(date -u +%FT%TZ) selfcheck: ${FAILS_CUR} подряд egress-провалов/деградаций → запускаю ${RECOVER_PATH}" >&2
      if "${RECOVER_PATH}" "${RECOVER_MAX_TRIES}" >&2; then
        write_state 0
        FAILS+=("auto-recover: переключились на резервную ноду")
      else
        FAILS+=("auto-recover: rotation провалился (см. лог recover)")
      fi
    fi
  else
    write_state 0
  fi
fi

# Финал
TS="$(date -u +%FT%TZ)"
FAILS_N="${#FAILS[@]}"

# Общий счётчик подряд-фейлов + TG-алёрт по порогу.
# Why: одиночные osечки (egress timeout / NTP моргнул) не должны звенеть в TG.
GEN_PREV=0
if [[ -r "${GENERAL_STATE_FILE}" ]]; then
  GEN_PREV="$(cat "${GENERAL_STATE_FILE}" 2>/dev/null || echo 0)"
fi
mkdir -p "${STATE_DIR}"

notify() {
  # $1 — текст-причина (для лога); сам notify-tg.sh подтянет journal-tail
  local reason="$1"
  echo "${TS} selfcheck: notify-tg → ${reason}"
  if [[ -x "${NOTIFY_SCRIPT}" ]]; then
    "${NOTIFY_SCRIPT}" "${SELFCHECK_UNIT}" || \
      echo "${TS} selfcheck: notify-tg.sh завершился с ошибкой" >&2
  fi
}

if [[ "${FAILS_N}" -eq 0 ]]; then
  echo "${TS} selfcheck OK (egress=${EGRESS:-?})"
  echo 0 >"${GENERAL_STATE_FILE}"
  # Recovery-нотификация: если до этого мы уже звонили о проблеме — закрыть инцидент.
  if [[ -f "${NOTIFIED_FLAG}" ]]; then
    notify "recovered after $(cat "${NOTIFIED_FLAG}" 2>/dev/null || echo "?" ) consecutive fails"
    rm -f "${NOTIFIED_FLAG}"
  fi
  exit 0
fi

echo "${TS} selfcheck FAIL (${FAILS_N}):" >&2
for f in "${FAILS[@]}"; do
  echo "  - ${f}" >&2
done

GEN_CUR=$(( GEN_PREV + 1 ))
echo "${GEN_CUR}" >"${GENERAL_STATE_FILE}"

# Алёрт только когда счётчик пересёк порог и мы ещё не звонили в этом инциденте.
if [[ "${GEN_CUR}" -ge "${ALERT_THRESHOLD}" && ! -f "${NOTIFIED_FLAG}" ]]; then
  echo "${GEN_CUR}" >"${NOTIFIED_FLAG}"
  notify "${GEN_CUR} consecutive fails ≥ threshold ${ALERT_THRESHOLD}"
fi

exit 1
{% endraw %}
