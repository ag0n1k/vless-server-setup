.idea/
.DS_Store

# Ansible
*.retry
.vault_pass
inventory/group_vars/all/vault.yml
inventory/host_vars/*/vault.yml
.cache/
facts/
*.log
ansible/.cache/
ansible/facts/
ansible/*.log

# Local secrets staged for vault encryption
.secrets-staging/

# Локальные бинари (wdtt-server и т.п.) — собираются make build-wdtt
.local/

# Защита от бинарей, попавших в корень репо (например, если make build-wdtt
# запускался не из корня или скачивались релизные бинари руками)
/server-linux-amd64
/server-linux-arm64
/vk-turn-proxy
/wdtt-server

# Локальные клиентские конфиги (.ovpn, .conf), сгенерированные плейбуками
.local-clients/
.local-peers/
.local-backups/
